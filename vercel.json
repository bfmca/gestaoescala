{
  "redirects": [
    {
      "source": "/",
      "destination": "https://educacaoemsaude.vercel.app/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "destination": "https://educacaoemsaude.vercel.app/esc/:path*",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
